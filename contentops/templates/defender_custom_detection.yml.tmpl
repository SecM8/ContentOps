payload:
  displayName: "${display_name}"
  isEnabled: true
  queryCondition:
    queryText: |
      DeviceProcessEvents
      | where Timestamp > ago(1h)
      | take 100
  schedule:
    period: "1H"
  detectionAction:
    alertTemplate:
      title: "${display_name}"
      description: TODO describe what this detection finds and recommended response.
