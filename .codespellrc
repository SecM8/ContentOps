[codespell]
# Codespell config for SIEMContent.
#
# Scope: detection metadata, narrative docs, Python source. The .git/
# tree, generated catalogs, the kql_strict C# project, audit JSONL,
# and the lockfile-style requirements.txt are skipped so codespell
# only flags author-controlled prose. KQL bodies inside envelopes
# remain in scope because typos in column names get parsed as
# undefined-column findings by kql_strict anyway, so codespell
# duplicates effort there only on KQL identifiers we'd otherwise
# pretend were real.
#
# ignore-words-list is a comma-separated allowlist of legitimate
# terms codespell would otherwise flag:
#   * "iif"   — KQL conditional (similar to SQL IIF).
#   * "te"    — technique identifier prefix (T1059, etc.).
#   * "ans"   — answers field in survey-style metadata.
#   * "fpr"   — false-positive rate.
#   * "alos"  — Azure Lab Operating Sample (used in a couple of refs).
#   * "iam"   — Identity and Access Management.
#   * "nd"    — "Nth detection" abbreviation.
#   * "te"    — see above.
# Add to this list rather than scattering inline `# codespell:ignore`
# comments.
skip = .git,.venv,venv,*.lock,requirements.txt,docs/reference/generated-catalog.md,tools/kql_strict,tools/kql_strict/schemas.json,tools/kql_strict/schemas_defender.json,audit,reports,test-reports,alerts-reports,.snapshot,.test-export,exports,.pytest_cache,detections,docs/detections
# Domain false positives + filename-bound IDs that would require renaming
# detections (cascading effect on audit trail / state.json) -- left alone
# on purpose. `unparseable` and `OT` are legitimate domain spellings:
#   * `unparseable` -- variant of `unparsable` widely used in Python /
#     PyYAML error messages; both are accepted English.
#   * `ot` (OT) -- Operational Technology, used in security taxonomies.
# Filename-bound typos kept until a coordinated renaming PR:
#   `registred`, `permisisons`, `detction`, `successfull` appear in
#   envelope ids that double as audit-trail keys.
# Upstream-published Microsoft template names live in
# `manifests/upstream_templates.json` (regenerated by
# `upstream-watchers.yml`); we don't unilaterally fix Microsoft's
# spellings since the manifests are an authoritative mirror:
#   * `activites` — appears in Microsoft template "GitHub Activites
#     from a New Country" (v1.0.0).
ignore-words-list = iif,te,ans,fpr,alos,iam,nd,childs,wel,unparseable,ot,registred,permisisons,detction,successfull,referance,occurences,activites,re-using
check-filenames =
check-hidden =
